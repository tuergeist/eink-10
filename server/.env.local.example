# Copy to .env.local and fill in. Used by `pdm run serve` for local dev.
EINK_PUSH_TOKEN=dev-push-change-me
EINK_READ_TOKEN=dev-read-change-me
EINK_DATA_DIR=./data-local
EINK_PUBLIC_BASE_URL=http://172.16.2.158:8989
EINK_REFRESH_INTERVAL_S=300
# Tell the board to overlay current time on the freshly fetched image.
# Time is rendered on-device with NTP, only when a new image arrives.
EINK_OVERLAY_CLOCK=true
